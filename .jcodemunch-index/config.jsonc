{
  "extra_ignore_patterns": ["node_modules/", ".git/", "__pycache__/", ".codegraph/", ".jcodemunch-index/", ".opencode/", ".playwright-mcp/", ".ruff_cache/"],
  "tool_tier_bundles": {
    "core": [
      "index_folder",
      "list_repos", "resolve_repo",
      "get_repo_outline", "get_file_tree", "get_file_outline",
      "search_symbols", "get_symbol_source", "get_file_content",
      "search_text", "get_context_bundle",
      "find_importers", "find_references",
      "get_call_hierarchy", "get_blast_radius"
    ]
  },
  "tool_profile": "core",
  "compact_schemas": true,
  "disabled_tools": [
    // test_summarizer — diagnostic: sends a probe to the AI summarizer and
    //   reports status (ok, timeout, error, misconfigured, disabled).
    //   Remove from this list to enable it, then call it from your MCP client.
    "test_summarizer",
    "analyze_perf",
    "announce_model",
    "audit_agent_config",
    "check_embedding_drift",
    "check_references",
    "check_rename_safe",
    "embed_repo",
    "find_dead_code",
    "get_changed_symbols",
    "get_churn_rate",
    "get_class_hierarchy",
    "get_coupling_metrics",
    "get_cross_repo_map",
    "get_dead_code_v2",
    "get_dependency_cycles",
    "get_dependency_graph",
    "get_extraction_candidates",
    "get_hotspots",
    "get_impact_preview",
    "get_layer_violations",
    "get_pr_risk_profile",
    "get_project_intel",
    "get_ranked_context",
    "get_related_symbols",
    "get_repo_health",
    "get_session_context",
    "get_session_snapshot",
    "get_session_stats",
    "get_signal_chains",
    "get_symbol_complexity",
    "get_symbol_diff",
    "get_symbol_importance",
    "get_symbol_provenance",
    "get_tectonic_map",
    "get_untested_symbols",
    "get_watch_status",
    "index_file",
    "index_repo",
    "invalidate_cache",
    "jcodemunch_guide",
    "plan_refactoring",
    "plan_turn",
    "register_edit",
    "render_diagram",
    "search_ast",
    "search_columns",
    "set_tool_tier",
    "suggest_queries",
    "summarize_repo",
    "test_summarizer",
    "tune_weights",
    "winnow_symbols",
  ]
}
